{
  "buildCommand": null,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/what-is-it", "destination": "/what-is-it.html" },
    { "source": "/docs", "destination": "/docs.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
